msgstr "الحرف المميزة"

#: .\core\templates\core\home.html:52 .\crafts\templates\crafts\riyadh.html:34
msgid "Sadu Weaving"
msgstr "نسيج السدو"

#: .\core\templates\core\home.html:53
msgid ""
"A well-known traditional weaving craft connected to desert culture and "
"Bedouin identity."
msgstr "حرفة نسيج تقليدية معروفة مرتبطة بثقافة الصحراء والهوية البدوية."

