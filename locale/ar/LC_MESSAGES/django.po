msgid "Top Attraction"
msgstr "أبرز معلم"

#: .\crafts\templates\crafts\region_detail.html:31
msgid "Major Events"
msgstr "الفعاليات الرئيسية"

#: .\crafts\templates\crafts\region_detail.html:38
msgid "Related Crafts"
msgstr "الحرف ذات الصلة"

#: .\crafts\templates\crafts\region_detail.html:55
msgid "Video"
msgstr "فيديو"

